        }
      }
    },
    "/api/projects/{projectId}/runs/{runId}/events": {
      "get": {
        "operationId": "streamRunEvents",
        "tags": ["stream"],
        "x-aor-route-id": "run-events",
        "x-aor-permission": "read",
        "x-aor-kind": "stream",
        "parameters": [
          { "$ref": "#/components/parameters/projectId" },
          { "$ref": "#/components/parameters/runId" }
        ],
        "responses": {
          "200": {
            "description": "Replay-safe server-sent event stream using live-run-event payloads.",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/AuthError" },
          "403": { "$ref": "#/components/responses/AuthError" }
        }
      }
    },
    "/api/projects/{projectId}/run-control/actions": {
      "post": {
        "operationId": "runControlAction",
        "tags": ["mutation"],
        "x-aor-route-id": "run-control-actions",
        "x-aor-permission": "mutate",
        "x-aor-kind": "mutation",
        "parameters": [{ "$ref": "#/components/parameters/projectId" }],
        "requestBody": { "$ref": "#/components/requestBodies/JsonObject" },
        "responses": {
          "200": { "$ref": "#/components/responses/JsonObject" },
          "400": { "$ref": "#/components/responses/JsonError" },
          "401": { "$ref": "#/components/responses/AuthError" },
          "403": { "$ref": "#/components/responses/AuthError" },
          "409": { "$ref": "#/components/responses/JsonError" }
        }
      }
    },
