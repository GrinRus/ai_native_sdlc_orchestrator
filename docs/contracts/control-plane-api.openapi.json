        }
      }
    },
    "/api/projects/{projectId}/runs/{runId}/policy-history": {
      "get": {
        "operationId": "getRunPolicyHistory",
        "tags": ["read"],
        "x-aor-route-id": "policy-history",
        "x-aor-permission": "read",
        "x-aor-kind": "read",
        "parameters": [
          { "$ref": "#/components/parameters/projectId" },
          { "$ref": "#/components/parameters/runId" }
        ],
        "responses": {
          "200": { "$ref": "#/components/responses/JsonObject" },
