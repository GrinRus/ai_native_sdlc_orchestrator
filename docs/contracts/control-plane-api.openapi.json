{
  "openapi": "3.1.0",
  "info": {
    "title": "AOR detached control-plane API",
    "version": "1.0.0-alpha",
    "description": "Machine-readable contract for the implemented self-hosted alpha HTTP/SSE control-plane routes. This spec describes the current hybrid module plus detached transport baseline; it does not claim hosted SaaS, full CLI-over-HTTP parity, or target-stack APIs."
  },
  "servers": [
    {
      "url": "http://localhost:{port}",
      "description": "Self-hosted detached control-plane transport",
      "variables": {
        "port": {
          "default": "3000"
        }
      }
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "read"
    },
    {
      "name": "mutation"
    },
    {
      "name": "stream"
    }
  ],
  "paths": {
    "/api/projects/{projectId}/state": {
      "get": {
        "operationId": "getProjectState",
        "tags": ["read"],
        "x-aor-route-id": "project-state",
        "x-aor-permission": "read",
        "x-aor-kind": "read",
        "parameters": [{ "$ref": "#/components/parameters/projectId" }],
        "responses": {
          "200": { "$ref": "#/components/responses/JsonObject" },
          "401": { "$ref": "#/components/responses/AuthError" },
          "403": { "$ref": "#/components/responses/AuthError" }
        }
      }
    },
    "/api/projects/{projectId}/packets": {
